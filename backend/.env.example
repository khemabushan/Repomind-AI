# ── App ───────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/repomind.db

# ── OpenAI (required) ────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LLM settings ──────────────────────────────────────
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-3-small

# ── Storage ───────────────────────────────────────────
FAISS_INDEX_DIR=./data/faiss
REPO_CLONE_DIR=./data/repos
REPO_MAX_SIZE_MB=500

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
